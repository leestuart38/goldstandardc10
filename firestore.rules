rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private tracker data (core doc + media shards)
    match /tracker/{docId} {
      allow read, write: if request.auth != null;
    }

    // Public build page (readable by anyone; writes require sign-in)
    match /publicBuilds/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
