rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Legacy single-build docs (kept for migration; do not delete)
    match /tracker/{docId} {
      allow read, write: if request.auth != null;
    }

    // Per-user garage: private builds + media shards + meta
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public build pages (readable by anyone; writes require sign-in)
    match /publicBuilds/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
